upstream backend_servers {
    {{ range service "web" }}
    server {{ .Address }}:{{ .Port }};
    {{ end }}
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name birdswatching.site www.birdswatching.site;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}
